# =============================================
# Railway Deployment Environment Variables
# =============================================

# Option 1: Railway auto-injects this when you link a PostgreSQL service
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Manual individual PostgreSQL variables (for local dev)
DB_HOST=localhost
DB_PORT=5432
DB_USER=proscient
DB_PASSWORD=proscient_secret
DB_NAME=proscient_db

# =============================================
# Admin Authentication
# =============================================
# Generate a hash: node -e "console.log(require('bcrypt').hashSync('your_password', 10))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_PASSWORD_HASH=
JWT_SECRET=your-random-secret-at-least-32-chars

# =============================================
# CORS
# =============================================
CORS_ORIGIN=https://psci-sol.com

# AI SERVICE CONFIGURATION (OpenRouter API)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# =============================================
# Beget FTP - Image Upload Storage
# =============================================
BEGET_FTP_HOST=ftp.psci-sol.com
BEGET_FTP_USER=labtec_prosci
BEGET_FTP_PASS=your_ftp_password_here
BEGET_FTP_UPLOAD_DIR=/public_html/uploads
BEGET_PUBLIC_BASE_URL=https://psci-sol.com/uploads/public_html/uploads
